{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-gemini-auth@latest"],
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "qwen3-coder:a3b": {
          "name": "Qwen3-Coder: a3b-30b (local)",
          "limit": {
            "context": 128000,
            "output": 65536
          }
        },
      }
    }
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "*": "ask",

      // Linux
      "ls *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "touch *": "ask",
      "mkdir *": "ask",
      "rm *": "ask",
      "cp *": "ask",
      "mv *": "ask",
      "dd *": "ask",
      "sudo *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "pip install *": "ask",
      "reboot": "ask",
      "shutdown": "ask",
      "kill *": "ask",
      "killall *": "ask",
      "docker *": "ask",
      "mkfs *": "ask",
      "fdisk *": "ask",
      "parted *": "ask",
      "format *": "ask",
      "brew install *": "ask",
      "brew upgrade *": "ask",
      "ssh *": "ask",
      "scp *": "ask",
      "rsync *": "ask",

      // Git
      "git branch *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git merge-base *": "allow",
      "git push": "ask",
      "git reset --hard *": "ask",
      "git clean *": "ask",
      "git branch -d *": "ask",
      "git branch -D *": "ask",
      "git rebase *": "ask",

      // Rust
      "cargo check *": "allow",

      // JS
      "npm install *": "ask",
      "npm run publish": "ask",
    },
    "doom_loop": "ask",
    "external_directory": "ask"
  }
}
