  "query": "\n            insert into dropspot.integration (organisation_id, slug, is_active, data)\n            values ($1, $2, $3, $4)\n            on conflict (organisation_id, slug)\n            do update set\n                is_active = $3,\n                data = $4,\n                updated_at = now(),\n                updated_by_id = $5\n            returning\n                id,\n                slug as \"slug: StorageType\",\n                organisation_id,\n                is_active,\n                data as \"data: Json<IntegrationData>\"\n        ",
