{
  "db_name": "PostgreSQL",
  "query": "\n            select\n              users.id,\n              users.first_name,\n              users.last_name,\n              users.email,\n              users.created_at,\n              users.updated_at,\n              users.updated_by_id,\n              users.organisation_id,\n              users.is_admin,\n              count(file.id)::int \"file_count!\"\n            from dropspot.users users\n            left join dropspot.file file\n            on file.created_by_id = users.id\n            group by users.id\n            having users.id = $1\n            order by users.created_at asc\n            limit 1\n        ",
