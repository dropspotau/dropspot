  "query": "\n            select \n                download.id,\n                download.file_id,\n                download.created_at,\n                users.id \"created_by_id?\",\n                users.email \"created_by_name?\",\n                download.download_ip as \"download_ip: IpAddr\",\n                download.expires_at\n            from dropspot.download download\n            left join dropspot.users users\n            on users.id = download.created_by_id\n            where download.id = $1\n            limit 1\n        ",
