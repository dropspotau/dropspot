  "query": "\n            select\n              organisation.id,\n              organisation.name,\n              organisation.created_at\n            from dropspot.organisation organisation\n            left join dropspot.users users\n            on users.organisation_id = organisation.id\n            where users.id = $1\n            limit 1\n        ",
